PORT=5050
MONGODB_URI=mongodb://127.0.0.1:27017/event-finder
JWT_SECRET=change-me-in-production
TICKETMASTER_API_KEY=
# true = always bundled sample events (ignores Ticketmaster key). false = use TM when key is set.
USE_SAMPLE_EVENTS=true
CLIENT_ORIGIN=http://localhost:5173

# Google AI Studio / Gemini — required for /api/assistant/chat
GEMINI_API_KEY=
# Optional override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-1.5-flash
